# Required
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Server Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# RAG Configuration
TOP_K_RESULTS=3
COLLECTION_NAME=thoughtful_ai_qa
